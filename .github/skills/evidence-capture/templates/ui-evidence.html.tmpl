<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>UI Evidence: {{CHANGE_TITLE}}</title>
<style>
  :root { color-scheme: light dark; font-family: system-ui, -apple-system, Segoe UI, sans-serif; }
  body { max-width: 960px; margin: 2rem auto; padding: 0 1rem; line-height: 1.5; }
  h1 { font-size: 1.5rem; margin-bottom: 0.25rem; }
  .meta { color: #666; font-size: 0.875rem; margin-bottom: 2rem; }
  .meta code { background: rgba(127,127,127,0.15); padding: 0 0.25rem; border-radius: 3px; }
  section { margin-bottom: 2rem; border-top: 1px solid #ddd; padding-top: 1rem; }
  video, img { max-width: 100%; height: auto; border: 1px solid #ccc; border-radius: 6px; display: block; }
  .ba { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .ba figure { margin: 0; }
  .ba figcaption { font-size: 0.875rem; color: #666; text-align: center; margin-top: 0.5rem; }
  footer { color: #666; font-size: 0.875rem; margin-top: 3rem; border-top: 1px solid #ddd; padding-top: 1rem; }
</style>
</head>
<body>

<h1>UI Evidence: {{CHANGE_TITLE}}</h1>

<p class="meta">
  Issue: <a href="{{ISSUE_URL}}">{{ISSUE_LINK_TEXT}}</a> .
  PR: <a href="{{PR_URL}}">{{PR_LINK_TEXT}}</a> .
  HEAD: <code>{{HEAD_SHA}}</code> .
  Captured: {{CAPTURE_TIMESTAMP_UTC}}
</p>

<section>
  <h2>What changed</h2>
  <p>{{CHANGE_SUMMARY_FROM_ISSUE}}</p>
</section>

<section>
  <h2>Recording</h2>
  <p>{{RECORDING_DESCRIPTION}}</p>
  <video controls preload="metadata" src="recording.mp4"></video>
</section>

<section>
  <h2>Before vs. after</h2>
  <div class="ba">
    <figure>
      <img src="before.png" alt="Before: {{BEFORE_ALT}}">
      <figcaption>Before -- baseline (<code>{{BASELINE_SHA_SHORT}}</code>)</figcaption>
    </figure>
    <figure>
      <img src="after.png" alt="After: {{AFTER_ALT}}">
      <figcaption>After -- this PR (<code>{{HEAD_SHA_SHORT}}</code>)</figcaption>
    </figure>
  </div>
</section>

<section>
  <h2>Verified observations</h2>
  <ul>
    <li>{{EXPECTED_OBSERVATION_1}}</li>
    <li>{{EXPECTED_OBSERVATION_2}}</li>
    <li>{{EXPECTED_OBSERVATION_3}}</li>
  </ul>
</section>

<section>
  <h2>Reproduce locally</h2>
  <pre><code>{{REPRO_COMMAND}}</code></pre>
</section>

<footer>
  Generated by the evidence-capture skill. See
  <code>.github/skills/evidence-capture/SKILL.md</code> for details.
</footer>

</body>
</html>
